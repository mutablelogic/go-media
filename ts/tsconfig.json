{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "useDefineForClassFields": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "assets/**/*.ts",
    "components/**/*.ts",
    "schema/**/*.ts",
    "httpclient/**/*.ts",
    "controllers/**/*.ts",
    "types/**/*.d.ts"
  ]
}
